{
  "name": "@daleal/eslint-config",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@daleal/eslint-config-ts": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  }
}
