{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": ".",
    "paths": {
      "@daleal/eslint-core": ["./packages/eslint-core/index.ts"],
      "@daleal/eslint-typescript": ["./packages/eslint-typescript/index.ts"],
      "@daleal/eslint-vue": ["./packages/eslint-vue/index.ts"]
    }
  },
  "include": ["eslint.config.ts", "packages/**/*.ts", "scripts/**/*.ts"]
}
