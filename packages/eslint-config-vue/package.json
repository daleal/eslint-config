{
  "name": "@daleal/eslint-config-vue",
  "version": "0.1.0",
  "description": "daleal's opinionated ESLint flat config for Vue + TypeScript projects",
  "homepage": "https://github.com/daleal/eslint-config/tree/main/packages/eslint-config-vue",
  "bugs": {
    "url": "https://github.com/daleal/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daleal/eslint-config.git"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@daleal/eslint-config-core": "^0.1.0",
    "@daleal/eslint-config-ts": "^0.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "typescript-eslint": "^8.56.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "peerDependencies": {
    "eslint": "^10",
    "typescript": "^5"
  }
}
