{
  "name": "@daleal/eslint-config-ts",
  "version": "0.1.4",
  "description": "daleal's opinionated ESLint flat config for TypeScript projects",
  "homepage": "https://github.com/daleal/eslint-config/tree/main/packages/eslint-config-ts",
  "bugs": {
    "url": "https://github.com/daleal/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daleal/eslint-config.git"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@daleal/eslint-config-core": "^0.1.4",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-import": "^2.32.0",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "eslint": "^9",
    "typescript": "^5"
  }
}
